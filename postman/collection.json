{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Service Provider API",
    "description": "REST API for managing outsourced service providers, their employees, vehicles, and compliance documents.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Returns 200 if the API is up."
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (pm.response.code === 200 && json.idToken) {",
                  "    pm.environment.set('id_token', json.idToken);",
                  "    console.log('id_token saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Authenticates with Firebase and returns a Firebase ID token. The test script automatically saves the token to the `id_token` environment variable."
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List Providers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["providers"],
              "query": [
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "20" },
                { "key": "status",  "value": "pending", "disabled": true },
                { "key": "country", "value": "BR",      "disabled": true }
              ]
            },
            "description": "Admin only. Returns a paginated list of providers. Optional filters: status (pending | pending_review | approved | inactive) and country (BR | US | DE | GB | FR)."
          }
        },
        {
          "name": "Create Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.environment.set('provider_id', response.provider.id);",
                  "    console.log('provider_id saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"corporateName\": \"Acme Logistics LLC\",\n  \"taxId\": \"12.345.678/0001-99\",\n  \"country\": \"BR\",\n  \"phone\": \"+55 11 99999-9999\",\n  \"email\": \"joao.silva@acme.com\",\n  \"address\": \"Rua das Flores, 123\",\n  \"city\": \"São Paulo\",\n  \"state\": \"SP\",\n  \"postalCode\": \"01310-100\",\n  \"representativeName\": \"João Silva\",\n  \"password\": \"Acme2026\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/providers",
              "host": ["{{base_url}}"],
              "path": ["providers"]
            },
            "description": "Public endpoint. Self-registration: creates a provider record together with the representative's Firebase Authentication account in a single atomic operation. Returns the created provider and user."
          }
        },
        {
          "name": "Submit for Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/me/submit",
              "host": ["{{base_url}}"],
              "path": ["providers", "me", "submit"]
            },
            "description": "Provider only. Signals readiness for admin review. Transitions the authenticated provider from pending to pending_review. Provider data becomes read-only while in review."
          }
        },
        {
          "name": "Get Provider",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}"]
            },
            "description": "Returns a single provider. Admins see any provider; providers see only their own record."
          }
        },
        {
          "name": "Approve Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "approve"]
            },
            "description": "Admin only. Approves a provider in pending_review status, transitioning it to approved. Compliance gating will be enforced once the compliance endpoint is implemented; for now, the transition is unconditional."
          }
        },
        {
          "name": "Reject Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Missing tax_id document. Please upload and resubmit.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "reject"]
            },
            "description": "Admin only. Rejects a provider in pending_review status, transitioning it back to pending. Optional 'reason' in body provides feedback to the provider (returned in the response but not persisted in the database)."
          }
        },
        {
          "name": "Deactivate Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/deactivate",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "deactivate"]
            },
            "description": "Admin only. Deactivates a provider, transitioning to inactive status. Accepts providers in pending, pending_review, or approved states."
          }
        }
      ]
    }
  ]
}
