{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Service Provider API",
    "description": "REST API for managing outsourced service providers, their employees, vehicles, and compliance documents.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Returns 200 if the API is up."
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (pm.response.code === 200 && json.idToken) {",
                  "    pm.environment.set('id_token', json.idToken);",
                  "    console.log('id_token saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Authenticates with Firebase and returns a Firebase ID token. The test script automatically saves the token to the `id_token` environment variable."
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List Providers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["providers"],
              "query": [
                { "key": "page",    "value": "1" },
                { "key": "limit",   "value": "20" },
                { "key": "status",  "value": "pending", "disabled": true },
                { "key": "country", "value": "BR",      "disabled": true }
              ]
            },
            "description": "Admin only. Returns a paginated list of providers. Optional filters: status (pending | approved | inactive) and country (BR | US | DE | GB | FR)."
          }
        },
        {
          "name": "Create Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"corporateName\": \"Acme Serviços Ltda\",\n  \"taxId\": \"12.345.678/0001-99\",\n  \"country\": \"BR\",\n  \"phone\": \"+55 11 99999-9999\",\n  \"email\": \"contato@acme.com\",\n  \"address\": \"Rua das Flores, 123\",\n  \"city\": \"São Paulo\",\n  \"state\": \"SP\",\n  \"postalCode\": \"01310-100\",\n  \"representativeName\": \"João Silva\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/providers",
              "host": ["{{base_url}}"],
              "path": ["providers"]
            },
            "description": "Admin only. Creates a provider record, registers the representative as a Firebase user, and returns a password setup link to be delivered to them."
          }
        },
        {
          "name": "Get Provider",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}"]
            },
            "description": "Returns a single provider. Admins see any provider; providers see only their own record."
          }
        },
        {
          "name": "Approve Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "approve"]
            },
            "description": "Admin only. Transitions a pending provider to approved status."
          }
        },
        {
          "name": "Deactivate Provider",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/deactivate",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "deactivate"]
            },
            "description": "Admin only. Transitions an approved provider to inactive status."
          }
        },
        {
          "name": "Regenerate Invite",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{id_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/providers/{{provider_id}}/regenerate-invite",
              "host": ["{{base_url}}"],
              "path": ["providers", "{{provider_id}}", "regenerate-invite"]
            },
            "description": "Admin only. Generates a new Firebase password setup link for the provider's representative user and returns it in the response."
          }
        }
      ]
    }
  ]
}
